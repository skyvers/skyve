<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<module name="kitchensink"
			title="Kitchen Sink"
			xmlns="http://www.skyve.org/xml/module"
			xsi:schemaLocation="http://www.skyve.org/xml/module ../../schemas/module.xsd"
			xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<homeRef>edit</homeRef>
	<homeDocument>KitchenSink</homeDocument>
	<documents>
		<document ref="KitchenSink" />
		<document ref="ContainerGrid" />
		<document ref="InlineGrid" />
		<document ref="ListAttributes" />
		<document ref="OrderedGrid" />
		<document ref="DataRepeater" />
		<document ref="EscapingFixture" />
		<document ref="UploadFixture" />
		<document ref="UploadFixtureGridRow" />
		<document ref="LookupDescription" />
	</documents>
	<roles>
		<role name="dev">
			<description>Dev</description>
			<privileges>
				<document name="KitchenSink" permission="_____">
					<contentPermission attribute="contentImage" />
					<contentPermission attribute="contentLink" />
					<contentPermission attribute="contentSignature" />
				</document>
				<document name="ContainerGrid" permission="CRUDD" />
				<document name="InlineGrid" permission="CRUDD" />
				<document name="ListAttributes" permission="CRUDD" />
				<document name="OrderedGrid" permission="CRUDD" />
				<document name="DataRepeater" permission="CRUDD" />
				<document name="EscapingFixture" permission="CRUDD">
					<action name="TrustedDisplayName" />
				</document>
				<document name="UploadFixture" permission="CRUDD">
					<action name="UploadGeneric" />
					<action name="UploadCamera" />
					<action name="UploadVideo" />
					<action name="UploadAll" />
					<contentPermission attribute="contentAutoNone" />
					<contentPermission attribute="contentAutoCamera" />
					<contentPermission attribute="contentAutoVideo" />
					<contentPermission attribute="contentAutoAll" />
					<contentPermission attribute="contentLinkNone" />
					<contentPermission attribute="contentLinkCamera" />
					<contentPermission attribute="contentLinkVideo" />
					<contentPermission attribute="contentLinkAll" />
					<contentPermission attribute="contentImageNone" />
					<contentPermission attribute="contentImageCamera" />
					<contentPermission attribute="contentImageAll" />
					<contentPermission attribute="contentVideoNone" />
					<contentPermission attribute="contentVideoVideo" />
					<contentPermission attribute="contentVideoAll" />
					<contentPermission attribute="contentDisabledAuto" />
					<contentPermission attribute="contentDisabledImage" />
					<contentPermission attribute="contentReadOnlyLink" />
					<contentPermission attribute="contentReadOnlyVideo" />
				</document>
				<document name="UploadFixtureGridRow" permission="CRUDD">
					<contentPermission attribute="boundColumnContent" />
					<contentPermission attribute="containerColumnContent" />
				</document>
				<document name="LookupDescription" permission="CRUDD" />
			</privileges>
		</role>
	</roles>
	<menu>
		<edit name="Kitchen Sink" document="KitchenSink">
			<role name="dev" />
		</edit>
		<link href="#" name="Calendar">
			<role name="dev" />
		</link>
		<list name="List" document="ListAttributes">
			<role name="dev" />
		</list>
		<edit name="Escaping Fixture" document="EscapingFixture">
			<role name="dev" />
		</edit>
		<edit name="Upload Fixture" document="UploadFixture">
			<role name="dev" />
		</edit>
		<link href="#" name="Map">
			<role name="dev" />
		</link>
		<link href="#" name="Tree">
			<role name="dev" />
		</link>
		<list name="Lookup values" document="LookupDescription">
			<role name="dev" />
		</list>
	</menu>
	<queries>
		<query name="qEscapingFixture" documentName="ListAttributes">
			<description>Small query used by the Kitchen Sink escaping fixture view.</description>
			<columns>
				<column binding="text" displayName="Text" />
			</columns>
		</query>
	</queries>
</module>
