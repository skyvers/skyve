<?xml version="1.0" encoding="UTF-8"?>
<view name="edit" title="admin.adminMenu.audits.list.displayName"
		xmlns="http://www.skyve.org/xml/view"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="http://www.skyve.org/xml/view ../../../../schemas/view.xsd">

	<tabPane>
		<tab title="admin.auditlist.archivetab.displayName" visible="showArchived">
			<listGrid continueConversation="true" 
                      model="ArchivedAuditListModel">
			</listGrid>
		</tab>
		<tab title="admin.auditlist.nonarchivetab.displayName" visible="showNonArchived">
			<listGrid continueConversation="true"  
			          query="qAudits">
			</listGrid>
		</tab>
	</tabPane>

    <actions/>
</view>
