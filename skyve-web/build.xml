			<arg value="src/css/editorial/main.css"/>
		</exec>
		<exec executable="/bin/sh" osfamily="unix" failonerror="true">
			<arg value="-lc"/>
			<arg value="npx --yes lightningcss-cli@${lightningcss.version} --minify --output-file src/main/resources/META-INF/resources/skyve/editorial/assets/css/main-min.css src/css/editorial/main.css"/>
		</exec>

		<!-- Minify Editorial JavaScript -->
	    <java jar="${closure.compiler.jar}" fork="true">
	        <arg value="--js=src/js/editorial/util.js"/>
	        <arg value="--js_output_file=src/main/resources/META-INF/resources/skyve/editorial/assets/js/util-min.js"/>
	        <arg value="--create_source_map=src/main/resources/META-INF/resources/skyve/editorial/assets/js/util-min.js.map"/>
	        <arg value="--source_map_include_content"/>
	    </java>
		<echo file="src/main/resources/META-INF/resources/skyve/editorial/assets/js/util-min.js" append="true">//# sourceMappingURL=util-min.js.map</echo>
	    <java jar="${closure.compiler.jar}" fork="true">
