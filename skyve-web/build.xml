		<mkdir dir="src/main/resources/META-INF/resources/skyve/editorial/assets/js"/>

	    <!-- Minify SmartClient JavaScript -->
	    <java jar="${closure.compiler.jar}" fork="true">
	        <!-- Common files -->
	        <arg value="--js=src/js/common/util.js"/>
	        
	        <!-- SmartClient files -->
	        <arg value="--js=src/js/desktop/util.js"/>
	        <arg value="--js=src/js/desktop/types.js"/>
	        <arg value="--js=src/js/desktop/windowStack.js"/>
	        <arg value="--js=src/js/desktop/reporting.js"/>
	        <arg value="--js=src/js/desktop/charting.js"/>
	        <arg value="--js=src/js/desktop/advancedFilter.js"/>
	        <arg value="--js=src/js/desktop/datagrid.js"/>
	        <arg value="--js=src/js/desktop/listgrid.js"/>
	        <arg value="--js=src/js/desktop/header.js"/>
	        <arg value="--js=src/js/desktop/listview.js"/>
	        <arg value="--js=src/js/desktop/editView.js"/>
	        <arg value="--js=src/js/desktop/harness.js"/>
	        
	        <!-- Output and source map settings -->
	        <arg value="--js_output_file=../skyve-web/src/main/resources/META-INF/resources/skyve/desktop/skyve-min.js"/>
	        <arg value="--create_source_map=../skyve-web/src/main/resources/META-INF/resources/skyve/desktop/skyve-min.js.map"/>
	        <arg value="--source_map_include_content"/>
	    </java>
		<echo file="../skyve-web/src/main/resources/META-INF/resources/skyve/desktop/skyve-min.js" append="true">//# sourceMappingURL=skyve-min.js.map</echo>

		<!-- Minify CSS with a modern parser. npx downloads the pinned tool only when this
		     explicit Ant target is run; normal Maven builds package the committed outputs. -->
		<exec executable="cmd" osfamily="windows" failonerror="true">
			<arg value="/c"/><arg value="npx.cmd"/>
			<arg value="--yes"/><arg value="lightningcss-cli@${lightningcss.version}"/><arg value="--minify"/>
			<arg value="--output-file"/><arg value="src/main/resources/META-INF/resources/skyve/css/basic-min.css"/>
			<arg value="src/css/basic.css"/>
		</exec>
		<exec executable="/bin/sh" osfamily="unix" failonerror="true">
			<arg value="-lc"/>
			<arg value="npx --yes lightningcss-cli@${lightningcss.version} --minify --output-file src/main/resources/META-INF/resources/skyve/css/basic-min.css src/css/basic.css"/>
		</exec>
		<exec executable="cmd" osfamily="windows" failonerror="true">
			<arg value="/c"/><arg value="npx.cmd"/>
			<arg value="--yes"/><arg value="lightningcss-cli@${lightningcss.version}"/><arg value="--minify"/>
			<arg value="--output-file"/><arg value="src/main/resources/META-INF/resources/skyve/css/prime-min.css"/>
			<arg value="src/css/prime.css"/>
		</exec>
		<exec executable="/bin/sh" osfamily="unix" failonerror="true">
