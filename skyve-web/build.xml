<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE project>
<project name="Compress" default="compressJavascript" basedir=".">
	<property name="closure.compiler.version" value="v20240317"/>
	<property name="closure.compiler.jar" value="lib/closure-compiler-${closure.compiler.version}.jar"/>
	<property name="closure.compiler.sha256" value="6b1250ac21c05bdd209dc515d9b6037b30b5555a284dd741ff0591a82848b7ce"/>
	<property name="lightningcss.version" value="1.32.0"/>

	<target name="prepareCompressionTools">
		<mkdir dir="lib"/>
		<get src="https://repo.maven.apache.org/maven2/com/google/javascript/closure-compiler/${closure.compiler.version}/closure-compiler-${closure.compiler.version}.jar"
				dest="${closure.compiler.jar}" skipexisting="true"/>
		<checksum file="${closure.compiler.jar}" algorithm="SHA-256"
				property="closure.compiler.actual.sha256"/>
		<fail message="Closure Compiler ${closure.compiler.version} checksum mismatch: expected ${closure.compiler.sha256}, got ${closure.compiler.actual.sha256}">
			<condition>
				<not>
					<equals arg1="${closure.compiler.actual.sha256}" arg2="${closure.compiler.sha256}" casesensitive="false"/>
				</not>
			</condition>
		</fail>
	</target>

	<target name="compressJavascript" depends="prepareCompressionTools">
