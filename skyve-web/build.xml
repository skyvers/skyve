			<arg value="--yes"/><arg value="lightningcss-cli@${lightningcss.version}"/><arg value="--minify"/>
			<arg value="--output-file"/><arg value="src/main/resources/META-INF/resources/skyve/css/upload-min.css"/>
			<arg value="src/css/upload.css"/>
		</exec>
		<exec executable="/bin/sh" osfamily="unix" failonerror="true">
